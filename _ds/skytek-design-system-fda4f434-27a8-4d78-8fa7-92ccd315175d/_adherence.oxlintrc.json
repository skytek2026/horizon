{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "app.jsx",
              "changelog-data.js",
              "charts-lib.jsx",
              "components/**",
              "copy-utilities.js",
              "icons.jsx",
              "section-apply.jsx",
              "section-asset-identity.jsx",
              "section-buttons-deep.jsx",
              "section-charts.jsx",
              "section-components.jsx",
              "section-data-primitives.jsx",
              "section-datetime.jsx",
              "section-domain.jsx",
              "section-elevation-usage.jsx",
              "section-elevation.jsx",
              "section-event-log.jsx",
              "section-export.jsx",
              "section-forms-deep.jsx",
              "section-foundations-meta.jsx",
              "section-foundations.jsx",
              "section-foundations2.jsx",
              "section-handoff.jsx",
              "section-layout-interaction-a11y.jsx",
              "section-modal.jsx",
              "section-states.jsx",
              "section-stewardship.jsx",
              "section-toast.jsx",
              "section-token-index.jsx",
              "section-voice.jsx",
              "tweaks-panel.jsx"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Exo|Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Exo, Inter, JetBrains Mono."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
